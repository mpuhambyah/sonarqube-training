graph LR
    subgraph Developer Laptop
        Scanner[Sonar Scanner]
        SonarLint[SonarLint - IDE Plugin]
    end

    subgraph SonarQube Server
        Web[Web Server - UI + API]
        CE[Compute Engine]
        ES[Search - Elasticsearch]
    end

    subgraph Database
        DB[(PostgreSQL)]
    end

    Scanner -->|scan report| Web
    SonarLint -.->|connected mode| Web
    Web --> CE
    CE --> DB
    ES --> DB
    Web --> ES

